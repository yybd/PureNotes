+// MARK: - PureNotes patch: per-paragraph BiDi direction
+
+// Returns YES if `c` is a strong RTL character (Hebrew / Arabic / etc.).
+// Mirrors Unicode BiDi class strong R + AL ranges that matter for our
+// content (Hebrew + Arabic + Arabic Presentation Forms). We don't pull in
+// ICU just to look up a property — the ranges below are stable and small.
+static inline BOOL pnIsStrongRTL(unichar c) {
+  return (c >= 0x0590 && c <= 0x05FF) ||  // Hebrew
+         (c >= 0x0600 && c <= 0x06FF) ||  // Arabic
+         (c >= 0x0700 && c <= 0x074F) ||  // Syriac
+         (c >= 0x0750 && c <= 0x077F) ||  // Arabic Supplement
+         (c >= 0x0780 && c <= 0x07BF) ||  // Thaana
+         (c >= 0x07C0 && c <= 0x07FF) ||  // NKo
+         (c >= 0x0800 && c <= 0x083F) ||  // Samaritan
+         (c >= 0x0840 && c <= 0x085F) ||  // Mandaic
+         (c >= 0x08A0 && c <= 0x08FF) ||  // Arabic Extended-A
+         (c >= 0xFB1D && c <= 0xFB4F) ||  // Hebrew Presentation Forms
+         (c >= 0xFB50 && c <= 0xFDFF) ||  // Arabic Presentation Forms-A
+         (c >= 0xFE70 && c <= 0xFEFF);    // Arabic Presentation Forms-B
+}
+
+// Returns YES if `c` is a strong LTR character (basic Latin + Latin
+// extended + Greek + Cyrillic). Anything else (digits, punctuation,
+// whitespace, ZWSP, control marks) is "weak" and skipped during scan.
+static inline BOOL pnIsStrongLTR(unichar c) {
+  return (c >= 'A' && c <= 'Z') ||
+         (c >= 'a' && c <= 'z') ||
+         (c >= 0x00C0 && c <= 0x024F) ||  // Latin-1 Supplement + Latin Ext
+         (c >= 0x0370 && c <= 0x03FF) ||  // Greek
+         (c >= 0x0400 && c <= 0x04FF);    // Cyrillic
+}
+
+- (void)refreshParagraphDirections {
+  NSTextStorage *storage = textView.textStorage;
+  NSString *fullString = storage.string;
+  NSUInteger length = fullString.length;
+  if (length == 0) return;
+
+  NSUInteger location = 0;
+  while (location < length) {
+    NSRange paragraphRange =
+        [fullString paragraphRangeForRange:NSMakeRange(location, 0)];
+    if (paragraphRange.length == 0) {
+      location = NSMaxRange(paragraphRange) + 1;
+      continue;
+    }
+
+    // BiDi P2/P3: scan for the first strong directional character. Skip
+    // ZWSP, bidi control marks, whitespace, digits, punctuation.
+    BOOL isRTL = NO;
+    BOOL foundStrong = NO;
+    for (NSUInteger i = paragraphRange.location;
+         i < NSMaxRange(paragraphRange) && !foundStrong; i++) {
+      unichar c = [fullString characterAtIndex:i];
+      if (pnIsStrongRTL(c)) {
+        isRTL = YES;
+        foundStrong = YES;
+      } else if (pnIsStrongLTR(c)) {
+        isRTL = NO;
+        foundStrong = YES;
+      }
+    }
+    // No strong char in paragraph (e.g. only digits / whitespace /
+    // newline). Leave the existing direction untouched — flipping
+    // empty paragraphs to LTR every keystroke causes caret jitter.
+    if (!foundStrong) {
+      location = NSMaxRange(paragraphRange);
+      continue;
+    }
+
+    NSWritingDirection writingDir = isRTL ? NSWritingDirectionRightToLeft
+                                          : NSWritingDirectionLeftToRight;
+    // Use NSTextAlignmentNatural so iOS resolves the alignment from the
+    // paragraph's `baseWritingDirection` AND — critically — applies
+    // `headIndent` as "from the leading edge" (which becomes the RIGHT
+    // edge for RTL paragraphs). With explicit NSTextAlignmentRight, iOS
+    // ignored `tailIndent` for RTL paragraphs that have textLists set,
+    // letting Hebrew text fill all the way to the right edge and cover
+    // the bullet drawn there.
+    NSTextAlignment alignment = NSTextAlignmentNatural;
+
+    // Mutate the existing paragraph style so we preserve headIndent,
+    // line height, textLists (list/checkbox metadata), etc.
+    NSParagraphStyle *existingStyle =
+        [storage attribute:NSParagraphStyleAttributeName
+                   atIndex:paragraphRange.location
+            effectiveRange:NULL];
+    NSMutableParagraphStyle *pStyle = existingStyle
+        ? [existingStyle mutableCopy]
+        : [[NSMutableParagraphStyle alloc] init];
+
+    // The list/checkbox style classes set `headIndent` to leave room for
+    // the marker on the leading edge. With NSTextAlignmentNatural +
+    // baseWritingDirection=RTL, iOS treats the leading edge as the RIGHT
+    // for Hebrew paragraphs, so the same `headIndent` value automatically
+    // produces a right-side indent. We don't need to swap to `tailIndent`
+    // — keep the existing headIndent untouched and just zero out tailIndent
+    // (which we may have set on a previous refresh pass back when we tried
+    // the swap approach).
+    CGFloat listIndent = MAX(pStyle.headIndent, -pStyle.tailIndent);
+    CGFloat firstLineIndent = MAX(pStyle.firstLineHeadIndent,
+                                   -pStyle.tailIndent);
+    CGFloat newHeadIndent = listIndent;
+    CGFloat newFirstLineHeadIndent = firstLineIndent;
+    CGFloat newTailIndent = 0;
+
+    // PureNotes patch: NO early-out. We always re-apply our settings, even
+    // if they match the current pStyle — RNE's handleDirtyRangesStyling can
+    // re-set attributes after our refresh in some flows, and an early-out
+    // would let those overwrites stick. Cost of always writing is minimal.
+    pStyle.alignment = alignment;
+    pStyle.baseWritingDirection = writingDir;
+    pStyle.headIndent = newHeadIndent;
+    pStyle.firstLineHeadIndent = newFirstLineHeadIndent;
+    pStyle.tailIndent = newTailIndent;
+    [storage addAttribute:NSParagraphStyleAttributeName
+                    value:pStyle
+                    range:paragraphRange];
+
+    location = NSMaxRange(paragraphRange);
+  }
+  // PureNotes patch: intentionally NOT touching typingAttributes here.
+  // An earlier version copied the previous-character's pStyle into
+  // typingAttributes, but when the cursor sat at a paragraph boundary the
+  // probed pStyle could be from a non-list paragraph — wiping textLists out
+  // of typingAttributes and breaking checkbox/bullet rendering on the next
+  // typed char. RNE's own typingAttributes management is sufficient.
+}
+
 @end
